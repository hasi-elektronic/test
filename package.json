{
  "name": "sickinger-kalkulation",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && esbuild worker/index.ts --bundle --format=esm --platform=neutral --target=es2022 --outfile=dist/_worker.js",
    "check": "tsc -p tsconfig.json && tsc -p tsconfig.worker.json",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=sickinger-kalkulationssystem --branch=main",
    "preview": "npm run build && wrangler pages dev dist"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250505.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
